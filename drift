#!/usr/bin/env bash
# DRIFT — one command from the repo root to launch the agent (or the relay).
#   ./drift                      boot your agent (default)
#   ./drift relay                run the rendezvous hub
#   ./drift agent --name x ...   any agent options
set -e
cd "$(dirname "$0")/apps/agent"
[ -d node_modules ] || npm install

exec npx tsx src/cli.ts "$@"
