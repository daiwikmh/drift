{
  "name": "drip",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @drip/web",
    "build": "npm run build --workspace @drip/web",
    "lint": "npm run lint --workspaces --if-present",
    "agent": "npm run start --workspace @drip/agent"
  }
}
