# DRIFT engine env. Locally these can live in the repo-root .env.local (auto-loaded);
# in production set them in the Railway service variables.

# Bybit API keys for live trading + auto-connect (accepts BYBIT_READ_* too).
BYBIT_API_KEY=
BYBIT_API_SECRET=
# "true" (default) uses Bybit testnet for trading; "false" uses mainnet.
BYBIT_TESTNET=true

# Comma-separated origins allowed to call the engine (the web cockpit URL).
# e.g. https://drift-web.up.railway.app  or  https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# On-chain MacroGuard (Mantle Sepolia). Deploy from contracts/ and paste the address.
# ETH_PRIVATE_KEY is the agent/deployer key — keep it only in .env.local, never commit.
MACROGUARD_ADDRESS=
ETH_PRIVATE_KEY=
# Optional overrides (defaults target Mantle Sepolia):
# MANTLE_RPC_URL=https://rpc.sepolia.mantle.xyz
# MANTLE_CHAIN_ID=5003

# LLM analyst (advisory only — never places orders). Set EITHER key; OpenRouter
# wins if both are present. The CLI also prompts for a key at startup if unset.
OPENROUTER_API_KEY=
NVIDIA_API_KEY=
# Optional overrides (defaults depend on the provider):
# LLM_BASE_URL=
# LLM_MODEL=

# Optional Telegram (alerts + two-way control bot). Token from @BotFather; chat-id
# is where alerts go (or message the bot /start once to bind it). Can also be set
# from the CLI (`telegram connect …`) or the web Connection panel.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
