# DRIFT agent env. Locally these can live in the repo-root .env.local (auto-loaded);
# in production set them as service variables.

# Avalanche Fuji RPC (defaults to the public endpoint).
# FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc

# The agent's wallet = its on-chain identity. Fund it from the Fuji faucet.
# Accepts AGENT_PRIVATE_KEY or the existing ETH_PRIVATE_KEY.
AGENT_PRIVATE_KEY=

# A2A transport: the WebSocket rendezvous relay every agent dials out to, so agents
# on different machines can reach each other. Run one locally or point at a deploy.
RELAY_URL=ws://localhost:8787

# LLM for the agent loop (OpenAI-compatible). Set EITHER; OpenRouter wins if both.
OPENROUTER_API_KEY=
NVIDIA_API_KEY=
# Optional overrides:
# LLM_MODEL=
# LLM_BASE_URL=
