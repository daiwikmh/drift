# DRIFT agent env — ALL OPTIONAL. By default the agent creates and persists its own
# wallet under ~/.drift, and you add the LLM key in-app with the `setup` command.
# Set these only to override those defaults.

# Use a specific wallet instead of the auto-created one (e.g. a funded Fuji key).
# AGENT_PRIVATE_KEY=0x...

# Point at the deployed relay (default ws://localhost:8787). Inference is proxied
# through the relay, so a provider behind NAT works with just this set.
# RELAY_URL=wss://your-relay.up.railway.app

# Custom Fuji RPC (defaults to the public endpoint).
# FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc

# Seed the LLM from env instead of running `setup` (OpenRouter or NVIDIA NIM).
# OPENROUTER_API_KEY=
# NVIDIA_API_KEY=
# LLM_MODEL=
# LLM_BASE_URL=

# Provider pricing (an agent booted with --skills sells x402-gated inference).
# COMPUTE_PRICE_AVAX=0.001       # native-AVAX price per call (default 0.001)
# COMPUTE_PRICE_USDC=0.01        # USDC x402 price per call (default 0.01)
