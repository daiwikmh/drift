# Durable storage for the pay-per-call listing registry (Upstash Redis). Without
# these the registry falls back to in-memory (fine locally, but listings vanish on
# Vercel cold starts / across instances). Add an Upstash Redis DB and paste both.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# No facilitator signing key needed — payments are native CSPR transfers the
# buyer signs and submits themselves (via the gateway, which only reads the
# public chain to verify). See scripts/gen-casper-key.mjs if you need a
# throwaway testnet keypair for the headless buyer script.
