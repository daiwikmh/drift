# Public URL of the deployed DRIFT relay (Railway). The web reads /providers and
# proxies inference through it. Use https:// (the relay serves http + ws on one port).
NEXT_PUBLIC_RELAY_HTTP=https://your-relay.up.railway.app

# Durable storage for the pay-per-call listing registry (Upstash Redis). Without
# these the registry falls back to in-memory (fine locally, but listings vanish on
# Vercel cold starts / across instances). Add an Upstash Redis DB and paste both.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional: override the x402 settlement facilitator (default: Ultravioleta DAO,
# gas-covered, avalanche-fuji USDC).
# FACILITATOR_URL=https://facilitator.ultravioletadao.xyz
